# Caddy reverse proxy for a single-instance nogent deploy.
#
# Install to /etc/caddy/Caddyfile, replace the domain and email, then:
#   systemctl enable --now caddy
#
# Caddy obtains and renews a Let's Encrypt cert automatically (HTTP-01 needs
# inbound :80; for a DNS-01 challenge instead, remove the :80 SG rule and add a
# `tls { dns <provider> ... }` block — see the Caddy docs for your DNS provider).
#
# The listener binds 127.0.0.1:8080 and only serves /api/github/webhooks and
# /healthz; everything else returns 404 here.

{
	# ACME contact for expiry notices. Replace with a real address.
	email ops@example.com
}

nogent.example.com {
	encode gzip

	# Only proxy the two real endpoints; reject everything else at the edge.
	@app path /api/github/webhooks /healthz
	handle @app {
		reverse_proxy 127.0.0.1:8080
	}
	handle {
		respond "not found" 404
	}

	# GitHub webhook payloads are small; cap the body at the edge too.
	request_body {
		max_size 2MB
	}
}
