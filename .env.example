# nogent-listener configuration. Copy to .env for local dev, or render to
# /etc/nogent/nogent.env on EC2 from AWS Secrets Manager. NEVER commit real
# values.

# ── GitHub App (from the App settings page) ───────────────────────────────
GITHUB_APP_ID=000000
# App private key. Provide EITHER the inline PEM (one line, \n-escaped) ...
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# ... OR a path to the PEM file (preferred for deploys — avoids multi-line env;
# this is what the Terraform/systemd setup uses). If both are set, inline wins.
# GITHUB_APP_PRIVATE_KEY_FILE=/etc/nogent/app-private-key.pem
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace-with-real-gemini-key
GEMINI_MODEL=gemini-3.5-flash
# Reasoning effort for thinking-capable (Gemini 3.x) models: minimal|low|medium|high.
# Leave empty for 2.5 models (which don't accept thinkingLevel).
GEMINI_THINKING_LEVEL=high

# ── Process ──────────────────────────────────────────────────────────────────
NOGENT_BIND_ADDR=127.0.0.1:8080
NOGENT_MAX_BODY_BYTES=2097152
# Optional: directory of Markdown system prompts to use instead of the ones
# embedded in the binary (see crates/nogent-core/prompts/). Lets you tune the
# review guidelines without recompiling, or reuse them across projects.
# NOGENT_PROMPTS_DIR=/etc/nogent/prompts
RUST_LOG=info
